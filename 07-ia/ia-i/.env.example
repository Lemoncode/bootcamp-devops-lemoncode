# Copia este archivo a .env y deja activa solo una opcion.

# Ollama
# Mas informacion: https://docs.ollama.com/api
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=nonecesitasapikey
LLM_MODEL=gemma4:e2b
# Si quieres usar un modelo cloud
# LLM_MODEL=gpt-oss:120b-cloud
# LLM_MODEL=gemma4:31b-cloud

# Ollama remoto
# Mas informacion: https://ollama.com/
# LLM_PROVIDER=ollama
# LLM_ENDPOINT=https://ollama.com/api
# LLM_API_KEY=tu_api_key
# LLM_MODEL=gemma3

# Docker Model Runner
# Mas informacion: https://docs.docker.com/ai/model-runner/
# LLM_PROVIDER=docker
# LLM_ENDPOINT=http://localhost:11434
# LLM_API_KEY=nonecesitasapikey
# LLM_MODEL=ai/llama3.2

# GitHub Models
# Mas informacion: https://docs.github.com/en/github-models
# LLM_PROVIDER=github
# LLM_ENDPOINT=https://models.github.ai/inference
# LLM_API_KEY=github_pat_xxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=openai/o4-mini

# LM Studio
# Mas informacion: https://lmstudio.ai/docs/app/api/endpoints/openai
# LLM_PROVIDER=llmstudio
# LLM_ENDPOINT=http://localhost:11434
# LLM_API_KEY=nonecesitasapikey
# LLM_MODEL=nombre-del-modelo-cargado

# Azure AI Foundry Local
# Mas informacion: https://learn.microsoft.com/azure/ai-foundry/how-to/develop/local-deployment-model-inference
# LLM_PROVIDER=foundrylocal
# LLM_ENDPOINT=http://localhost:11434
# LLM_API_KEY=nonecesitasapikey
# LLM_MODEL=nombre-del-modelo

# OpenRouter
# Mas informacion: https://openrouter.ai/docs/api-reference/overview
# LLM_PROVIDER=openrouter
# LLM_ENDPOINT=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-tu_api_key
# LLM_MODEL=qwen/qwen3.6-plus:free
